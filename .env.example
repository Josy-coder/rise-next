# Application
ENVIRONMENT=development

# Auth
BETTER_AUTH_SECRET=replace_with_your_secret
BETTER_AUTH_URL=http://localhost:5173

# Cloudflare
# For local dev, these will be mock/local values
CLOUDFLARE_ACCOUNT_ID=your_account_id
D1_DATABASE_ID=your_d1_id
R2_BUCKET_NAME=your_r2_bucket
KV_NAMESPACE_ID=your_kv_id

# These will be configured automatically in production by Cloudflare Pages